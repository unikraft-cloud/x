{{- /*
  Template for csv-enum-gen. Renders a Go file from a CSV.

  Data:
    .Config              - the JSON config (Package, Type, Fields, Unknown, ...)
    .Rows                - []map[string]string in CSV (or configured-sort) order
    .SortedRows          - []map[string]string sorted alphabetically by KeyColumn

  Funcs:
    lit value goType     - format a CSV string as a Go literal
    field cfg colName    - look up the Field for a CSV column (errors if missing)
    recv typeName        - one-character lowercase receiver name
*/ -}}
{{- $cfg := .Config -}}
{{- $recv := recv $cfg.Type -}}
{{- $stringField := field $cfg $cfg.StringColumn -}}
{{- if $cfg.BuildTags }}//go:build {{ $cfg.BuildTags }}

{{ end -}}
{{- if $cfg.Header }}{{ $cfg.Header }}

{{ end -}}
// Code generated by csv-enum-gen; DO NOT EDIT.

package {{ $cfg.Package }}

import (
	"database/sql/driver"
	"strings"
)

type {{ $cfg.Type }} struct {
{{- range $cfg.Fields }}
	{{ .Name }} {{ .Type }}
{{- end }}
}

func ({{ $recv }} {{ $cfg.Type }}) String() string {
	return {{ $recv }}.{{ $stringField.Name }}
}

// Scan implements the sql.Scanner interface.
func ({{ $recv }} *{{ $cfg.Type }}) Scan(value any) error {
	v := To{{ $cfg.Type }}(value.(string))
{{- range $cfg.Fields }}
	{{ $recv }}.{{ .Name }} = v.{{ .Name }}
{{- end }}
	return nil
}

// Value implements the driver.Valuer interface.
func ({{ $recv }} {{ $cfg.Type }}) Value() (driver.Value, error) {
{{- if $cfg.Unknown }}
	if len({{ $recv }}.{{ $stringField.Name }}) == 0 {
		return {{ $cfg.Unknown.Var }}, nil
	}
{{- end }}
	return {{ $recv }}.{{ $stringField.Name }}, nil
}

{{ if $cfg.Unknown -}}
var {{ $cfg.Unknown.Var }} = {{ $cfg.Type }}{
{{- range $i, $f := $cfg.Fields }}{{ if $i }}, {{ end }}{{ lit (index $cfg.Unknown.Values $f.Column) $f.Type }}{{ end -}}
}

{{ end -}}
//nolint:misspell
var (
{{- range $row := .Rows }}
	{{ index $row $cfg.KeyColumn }} = {{ $cfg.Type }}{
		{{- range $i, $f := $cfg.Fields }}{{ if $i }}, {{ end }}{{ lit (index $row $f.Column) $f.Type }}{{ end -}}
	}
{{- end }}
)

// Values returns a slice that represents all the possible values of
// the {{ $cfg.Type }} enum. This list is sorted alphabetically for fast lookup.
func Values() []{{ $cfg.Type }} {
	return []{{ $cfg.Type }}{
{{- range .SortedRows }}
		{{ index . $cfg.KeyColumn }},
{{- end }}
	}
}

// To{{ $cfg.Type }} returns the {{ $cfg.Type }} whose {{ $stringField.Name }} matches r, or {{ if $cfg.Unknown }}{{ $cfg.Unknown.Var }}{{ else }}the zero value{{ end }} if none match.
func To{{ $cfg.Type }}(r string) {{ $cfg.Type }} {
	switch strings.ToLower(r) {
{{- range .Rows }}
	case {{ index . $cfg.KeyColumn }}.String():
		return {{ index . $cfg.KeyColumn }}
{{- end }}
	default:
		return {{ if $cfg.Unknown }}{{ $cfg.Unknown.Var }}{{ else }}{{ $cfg.Type }}{}{{ end }}
	}
}
